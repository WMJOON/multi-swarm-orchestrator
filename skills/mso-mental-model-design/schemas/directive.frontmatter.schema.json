{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive.frontmatter.schema.json",
  "title": "Directive Frontmatter",
  "type": "object",
  "required": ["id", "type", "name", "domain", "taxonomy_path"],
  "properties": {
    "id": {"type": "string", "pattern": "^dir-\\d{3}"},
    "type": {
      "type": "string",
      "enum": ["framework", "instruction", "prompt"]
    },
    "name": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "taxonomy_path": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {"type": "string", "minLength": 1}
    },
    "concepts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "applicable_vertex_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["agent", "skill", "tool", "model"]
      }
    },
    "applicable_motifs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["chain", "star", "fork_join", "loop", "diamond", "switch"]
      }
    },
    "related": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
