# (생성물) root-workflow-template.yaml → ABox TTL. wf_to_ttl.py serialize 결과.
@prefix wf: <https://mso.dev/ontology/workflow#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://mso.dev/ontology/workflow#milestone/m-core-modules-ready> a wf:Milestone ;
    wf:milestoneOf <https://mso.dev/ontology/workflow#phase/phase-02-development> .

<https://mso.dev/ontology/workflow#milestone/m-final-handoff> a wf:Milestone ;
    wf:milestoneOf <https://mso.dev/ontology/workflow#phase/phase-05-delivery> .

<https://mso.dev/ontology/workflow#milestone/m-testing-complete> a wf:Milestone ;
    wf:milestoneOf <https://mso.dev/ontology/workflow#phase/phase-03-testing> .

<https://mso.dev/ontology/workflow#module/03.sensitive-data-masking> a wf:Module ;
    wf:criticalDep <https://mso.dev/ontology/workflow#module/01.consultdata> .

<https://mso.dev/ontology/workflow#module/04.AIKON7> a wf:Module ;
    wf:criticalDep <https://mso.dev/ontology/workflow#module/02.AI-Chatbot-Policy>,
        <https://mso.dev/ontology/workflow#module/10.RAG-Corpus-Dataset> .

<https://mso.dev/ontology/workflow#module/02.AI-Chatbot-Policy> a wf:Module ;
    wf:criticalDep <https://mso.dev/ontology/workflow#module/01.consultdata> .

<https://mso.dev/ontology/workflow#module/10.RAG-Corpus-Dataset> a wf:Module .

<https://mso.dev/ontology/workflow#phase/phase-01-discovery> a wf:Phase ;
    wf:description "모듈별 요구사항 분석, 범위 정의, 리소스 할당" ;
    wf:label "발견 & 계획 (Discovery & Planning)" ;
    wf:refersTo "01.consultdata/01.consultdata-workflow-00.yaml#discovery",
        "02.AI-Chatbot-Policy/02.AI-Chatbot-Policy-workflow-00.yaml#discovery",
        "03.sensitive-data-masking/03.sensitive-data-masking-workflow-00.yaml#discovery",
        "04.AIKON7/04.AIKON7-workflow-00.yaml#discovery",
        "10.RAG-Corpus-Dataset/10.RAG-Corpus-Dataset-workflow-00.yaml#discovery" ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#phase/phase-04-documentation> a wf:Phase ;
    wf:dependsOn <https://mso.dev/ontology/workflow#phase/phase-03-testing> ;
    wf:description "최종 산출물 문서화, 사용자 가이드, 인계 문서 작성" ;
    wf:label "문서화 & 전달 (Documentation & Delivery)" ;
    wf:refersTo "docs/01-consultdata.md",
        "docs/02-chatbot-policy.md",
        "docs/03-sensitive-data-masking.md",
        "docs/04-aikon7-rag-eval.md",
        "docs/10-rag-corpus-dataset.md" ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#phase/phase-05-delivery> a wf:Phase ;
    wf:dependsOn <https://mso.dev/ontology/workflow#phase/phase-04-documentation> ;
    wf:description "최종 검수, 벤더 인계, 운영 인수인계" ;
    wf:label "인계 & 배포 (Handoff & Deployment)" ;
    wf:refersTo "04.AIKON7/2026-05-13 전달 문서/분석_결과_보고서.md" ;
    wf:status "pending" .

<https://mso.dev/ontology/workflow#module/01.consultdata> a wf:Module .

<https://mso.dev/ontology/workflow#phase/phase-02-development> a wf:Phase ;
    wf:dependsOn <https://mso.dev/ontology/workflow#phase/phase-01-discovery> ;
    wf:description "각 모듈의 핵심 기능 개발 및 구현" ;
    wf:label "개발 & 구현 (Development & Implementation)" ;
    wf:parallel true ;
    wf:refersTo "01.consultdata/01.consultdata-workflow-00.yaml#development",
        "02.AI-Chatbot-Policy/02.AI-Chatbot-Policy-workflow-00.yaml#development",
        "03.sensitive-data-masking/03.sensitive-data-masking-workflow-00.yaml#development",
        "04.AIKON7/04.AIKON7-workflow-00.yaml#development",
        "10.RAG-Corpus-Dataset/10.RAG-Corpus-Dataset-workflow-00.yaml#development" ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#phase/phase-03-testing> a wf:Phase ;
    wf:dependsOn <https://mso.dev/ontology/workflow#phase/phase-02-development> ;
    wf:description "각 모듈의 품질 검증, 성능 벤치마크, 통합 테스트" ;
    wf:label "테스트 & 평가 (Testing & Evaluation)" ;
    wf:parallel true ;
    wf:refersTo "01.consultdata/01.consultdata-workflow-00.yaml#testing",
        "02.AI-Chatbot-Policy/02.AI-Chatbot-Policy-workflow-00.yaml#testing",
        "03.sensitive-data-masking/03.sensitive-data-masking-workflow-00.yaml#testing",
        "04.AIKON7/04.AIKON7-workflow-00.yaml#testing",
        "10.RAG-Corpus-Dataset/10.RAG-Corpus-Dataset-workflow-00.yaml#testing" ;
    wf:status "active" .


