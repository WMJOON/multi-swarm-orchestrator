@prefix wf: <https://mso.dev/ontology/workflow#> .

<https://mso.dev/ontology/workflow#criticaldep/policy-engine__ingestion> a wf:CriticalDependency ;
    wf:cdFrom "policy-engine" ;
    wf:cdTo "ingestion" ;
    wf:description "정책 수립을 위한 상담 데이터 분석 필요" .

<https://mso.dev/ontology/workflow#keydecision/14d03a75> a wf:KeyDecision ;
    wf:decisionText "RAG 평가 엔진을 GitHub submodule로 관리" ;
    wf:impactModule "rag-eval" ;
    wf:rationale "독립적인 버전 관리와 외부 협업 경계를 분리하기 위함" .

<https://mso.dev/ontology/workflow#milestone/m-core-modules-ready> a wf:Milestone ;
    wf:label "모든 핵심 모듈 완성" ;
    wf:milestoneDate "2026-05-21" ;
    wf:milestoneOf <https://mso.dev/ontology/workflow#workflow/workflow-00/development> ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#milestone/m-testing-complete> a wf:Milestone ;
    wf:label "모든 모듈 테스트 완료" ;
    wf:milestoneDate "2026-05-22" ;
    wf:milestoneOf <https://mso.dev/ontology/workflow#workflow/workflow-00/testing> ;
    wf:status "pending" .

<https://mso.dev/ontology/workflow#module/policy-engine> a wf:Module ;
    wf:criticalDep <https://mso.dev/ontology/workflow#module/ingestion> .

<https://mso.dev/ontology/workflow#project/workflow-00> a wf:Project ;
    wf:created "2026-05-21" ;
    wf:description "프로젝트 root workflow. 모듈 sub-workflow, artifact supply chain, eval gate를 조율한다." ;
    wf:label "AI Chatbot 1.0 - Root Workflow" ;
    wf:owner "owner@example.com" ;
    wf:version "1.0.0" .

<https://mso.dev/ontology/workflow#sc/all_modules_documented> a wf:SuccessCriterion ;
    wf:scKey "all_modules_documented" ;
    wf:scValue "모든 모듈 docs/ 문서 작성 완료" .

<https://mso.dev/ontology/workflow#sc/stakeholder_approval> a wf:SuccessCriterion ;
    wf:scKey "stakeholder_approval" ;
    wf:scValue "벤더 협업 완료 및 승인" .

<https://mso.dev/ontology/workflow#workflow/workflow-00> a wf:Workflow ;
    wf:has_subWorkflow <https://mso.dev/ontology/workflow#workflow/workflow-00/development>,
        <https://mso.dev/ontology/workflow#workflow/workflow-00/discovery>,
        <https://mso.dev/ontology/workflow#workflow/workflow-00/testing> .

<https://mso.dev/ontology/workflow#module/ingestion> a wf:Module .

<https://mso.dev/ontology/workflow#node/development/development-s-001> a wf:Node,
        wf:Step,
        wf:Task ;
    wf:deliverables "generated/module-output.md" ;
    wf:directory <https://mso.dev/ontology/workflow#node/development/development-s-001_dir_generated_>,
        <https://mso.dev/ontology/workflow#node/development/development-s-001_dir_src_> ;
    wf:inWorkflow <https://mso.dev/ontology/workflow#workflow/workflow-00/development> ;
    wf:instruction "설계된 workflow에 따라 핵심 모듈 산출물을 구현한다." ;
    wf:label "핵심 모듈 구현" ;
    wf:next <https://mso.dev/ontology/workflow#node/development/development-e-001> ;
    wf:status "active" .

<https://mso.dev/ontology/workflow#node/development/development-s-001_dir_generated_> wf:dirPath "generated/" ;
    wf:dirRole "output" .

<https://mso.dev/ontology/workflow#node/development/development-s-001_dir_src_> wf:dirPath "src/" ;
    wf:dirRole "input" .

<https://mso.dev/ontology/workflow#node/discovery/discovery-s-001> a wf:Node,
        wf:Step,
        wf:Task ;
    wf:deliverables "planning/requirements.md" ;
    wf:inWorkflow <https://mso.dev/ontology/workflow#workflow/workflow-00/discovery> ;
    wf:instruction "이해관계자 요구사항과 입력 artifact를 수집한다." ;
    wf:label "요구사항 수집" ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#node/testing/testing-e-001> a wf:Eval,
        wf:Node ;
    wf:criteria "integration tests pass" ;
    wf:harness "integration-test" ;
    wf:inWorkflow <https://mso.dev/ontology/workflow#workflow/workflow-00/testing> ;
    wf:label "최종 통합 평가" ;
    wf:onFail "manual_review" ;
    wf:oracleType "metric" ;
    wf:status "pending" .

<https://mso.dev/ontology/workflow#node/development/development-e-001> a wf:Eval,
        wf:Node ;
    wf:criteria "unit tests pass" ;
    wf:harness "unit-test" ;
    wf:inWorkflow <https://mso.dev/ontology/workflow#workflow/workflow-00/development> ;
    wf:label "구현 품질 평가" ;
    wf:onFail "block" ;
    wf:oracleType "metric" ;
    wf:status "pending" .

<https://mso.dev/ontology/workflow#workflow/workflow-00/discovery> a wf:Workflow ;
    wf:description "모듈별 요구사항 분석, 범위 정의, 리소스 할당" ;
    wf:hasNode <https://mso.dev/ontology/workflow#node/discovery/discovery-s-001> ;
    wf:label "발견 & 계획" ;
    wf:status "completed" .

<https://mso.dev/ontology/workflow#workflow/workflow-00/testing> a wf:Workflow ;
    wf:description "통합 테스트와 최종 평가" ;
    wf:hasNode <https://mso.dev/ontology/workflow#node/testing/testing-e-001> ;
    wf:label "테스트 & 평가" ;
    wf:status "pending" .

<https://mso.dev/ontology/workflow#workflow/workflow-00/development> a wf:Workflow ;
    wf:description "각 모듈의 핵심 기능 개발 및 구현" ;
    wf:hasNode <https://mso.dev/ontology/workflow#node/development/development-e-001>,
        <https://mso.dev/ontology/workflow#node/development/development-s-001> ;
    wf:label "개발 & 구현" ;
    wf:status "active" .
