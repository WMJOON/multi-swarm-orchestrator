@prefix wf:   <https://mso.dev/ontology/workflow#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ═══════════════════════════════════════════════════════════════════════════════
# !!! 생성물 — 직접 편집 금지. 소스: references/schemas/*.yaml
# !!! 재생성: python scripts/schemas_to_tbox.py
# ═══════════════════════════════════════════════════════════════════════════════

wf: a owl:Ontology ;
    rdfs:label "MSO Workflow Ontology"@ko ;
    rdfs:comment "schemas/*.yaml 에서 생성된 TBox. ABox 는 이 타입에 정합해야 한다."@ko ;
    owl:versionInfo "0.3.0" .


# ─── 클래스 (schema type) ──────────────────────────────────────────────────────
wf:Node a owl:Class ; rdfs:label "Node"@ko ; rdfs:comment "실행 노드 상위."@ko .
wf:Branch a owl:Class ; rdfs:label "Branch"@ko ;
    rdfs:comment "decision 노드의 조건별 분기. decision.branches[] 의 각 항목. on(조건) → goto(이동 node id) 매핑. 생략 시 sequential next. | invariants: on 비어있지 않음 on 은 부모 decision 의 judge_branch_conditions[judge] 에 속해야 함 (SHACL core 불가 → SPARQL/prose)"@ko .
wf:Decision a owl:Class ; rdfs:subClassOf wf:Node ; rdfs:label "Decision"@ko ;
    rdfs:comment "분기/판단 노드. workflow graph 는 task/decision 노드와 process edge 로 구성된다. user decision 은 HITL/HITLFE/HOTL/HOOTL judge 로 표현하고, agent decision 은 AGENT judge 로 표현한다. 산출물 품질평가/판단 주체는 별도의 oracle gate로 표현한다. | invariants: id 는 워크플로우 내 unique judge ∈ {HITL, HITLFE, HOTL, HOOTL, AGENT} Decision gate와 Oracle gate는 분리한다 branches[].on 은 judge_branch_conditions[judge] 에 속해야 함 HITL/HITLFE 일 때 owner 필수; HITLFE 일 때 threshold 필수"@ko .
wf:Group a owl:Class ; rdfs:subClassOf wf:Node ; rdfs:label "Group"@ko ;
    rdfs:comment "여러 노드를 Mermaid subgraph로 묶는 컨테이너. | invariants: id 는 워크플로우 내 unique steps 비어있지 않음"@ko .
wf:Oracle a owl:Class ; rdfs:subClassOf wf:Node ; rdfs:label "Oracle"@ko ;
    rdfs:comment "산출물 판단 주체 또는 품질평가자 게이트. Decision gate와 분리한다. Decision gate는 process branch/진행 판단을 담당하고, Oracle gate는 산출물의 품질·정합·수용 가능성을 평가한다. feedback loop 안에 Oracle gate가 없으면 산출물이 재귀적으로 소비되며 drift가 누적될 수 있다. | invariants: id 는 워크플로우 내 unique oracle_type ∈ {user, agent, metric} criteria 최소 1개 이상 Decision gate와 Oracle gate는 분리한다"@ko .
wf:SlotFillingOracle a owl:Class ; rdfs:subClassOf wf:Oracle ; rdfs:label "SlotFillingOracle"@ko ;
    rdfs:comment "entity slot 충족 여부를 누적 평가하는 Oracle 서브타입. 단일 산출물 품질 판정이 아니라 복수 슬롯(EntitySlot)을 하나씩 채워가는 점진적 수집 게이트다. 모든 슬롯이 filled=true 가 되면 order artifact를 생성하고 orderTarget step에 전달(order 발행). 슬롯 미충족 상태에서는 평가 루프를 지속한다. 재수집이 필요하면 onFail 경로로 반환한다. schema 없음 — 여기서 직접 정의. | invariants: hasSlot 최소 1개 이상 orderTarget 비어있지 않음 orderArtifact 비어있지 않음 oracleType 존재 evaluator 존재"@ko .
wf:EntitySlot a owl:Class ; rdfs:label "EntitySlot"@ko ;
    rdfs:comment "SlotFillingOracle의 개별 슬롯 정의. 슬롯 이름·충족 조건·현재 채움 여부를 보유한다. schema 없음 — 여기서 직접 정의. | invariants: slotName 비어있지 않음 slotConstraint 비어있지 않음 slotFilled: null(미평가) → false(미충족) → true(충족) 전이"@ko .
wf:Phase a owl:Class ; rdfs:label "Phase"@ko ;
    rdfs:comment "워크플로우의 단계(phase) 컨테이너. | invariants: id 비어있지 않음 status ∈ {completed, active, pending} steps 또는 workflows 둘 중 하나는 존재해야 함 (둘 다 비면 ERROR) workflows[] 각 항목은 workflow_ref.schema.yaml 의 invariant 를 따름"@ko .
wf:Step a owl:Class ; rdfs:subClassOf wf:Node ; rdfs:label "Step"@ko ;
    rdfs:comment "실행 작업 노드. I/O는 선택적. | invariants: id 는 워크플로우 내 unique label 비어있지 않음 instruction 비어있지 않음 (지시격 — 실행 지시. SHACL StepShape 강제) directories[].path 는 scaffold(index.yaml) 에 등록된 경로여야 함 (cross-skill invariant)"@ko .
wf:Validation a owl:Class ; rdfs:subClassOf wf:Node ; rdfs:label "Validation"@ko ;
    rdfs:comment "자동 검증 하네스 노드. 스크립트·테스트 러너·스키마 검증기 등이 자동으로 pass/fail 을 판정하는 게이트. decision(사람/모델 판단) 과 명확히 구분. | invariants: id 는 워크플로우 내 unique label 비어있지 않음 harness 비어있지 않음 (자동 실행 주체가 명시되어야 함) pass_criteria 최소 1개 이상 decision 의 judge 와 혼용 금지 — validation 은 자동 판정, decision 은 판단 주체 필요 directories[].path 는 scaffold(index.yaml) 에 등록된 경로여야 함 (cross-skill invariant)"@ko .
wf:WorkflowRef a owl:Class ; rdfs:label "WorkflowRef"@ko ;
    rdfs:comment "계층 workflow 참조. root workflow YAML 의 `phase.workflows[]` 또는 모듈 workflow YAML 의 `sub_workflow:` 필드에서 사용. sub workflow 의 phase/group id 를 anchor 로 가리켜 subgraph 형태로 통합한다. | invariants: ref 비어있지 않음 module 비어있지 않음 ref 의 file path 는 scaffold module:{module}.path 의 자손이어야 함 (cross-skill invariant) ref 의 anchor (있을 경우) 는 sub 파일 내 phase/group id 와 일치해야 함 module 필드 값은 ref 파일 자체가 선언한 module id 와 동일해야 함"@ko .

# ─── Property (schema fields) ──────────────────────────────────────────────────
wf:artifacts a owl:DatatypeProperty ; rdfs:label "artifacts"@ko ; rdfs:domain wf:Phase ; rdfs:range xsd:string .
wf:criteria a owl:DatatypeProperty ; rdfs:label "criteria"@ko ; rdfs:domain wf:Oracle ; rdfs:range xsd:string .
wf:defaultJudge a owl:DatatypeProperty ; rdfs:label "defaultJudge"@ko ; rdfs:domain wf:Phase ; rdfs:range xsd:string .
wf:deliverables a owl:DatatypeProperty ; rdfs:label "deliverables"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Step, Validation"@ko .
wf:description a owl:DatatypeProperty ; rdfs:label "description"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Decision, Oracle, Phase"@ko .
wf:evaluator a owl:DatatypeProperty ; rdfs:label "evaluator"@ko ; rdfs:domain wf:Oracle ; rdfs:range xsd:string .
wf:goto a owl:DatatypeProperty ; rdfs:label "goto"@ko ; rdfs:domain wf:Branch ; rdfs:range xsd:string .
wf:harness a owl:DatatypeProperty ; rdfs:label "harness"@ko ; rdfs:domain wf:Validation ; rdfs:range xsd:string .
wf:harnessPropagate a owl:DatatypeProperty ; rdfs:label "harnessPropagate"@ko ; rdfs:domain wf:WorkflowRef ; rdfs:range xsd:boolean .
wf:instruction a owl:DatatypeProperty ; rdfs:label "instruction"@ko ; rdfs:domain wf:Step ; rdfs:range xsd:string .
wf:judge a owl:DatatypeProperty ; rdfs:label "judge"@ko ; rdfs:domain wf:Decision ; rdfs:range xsd:string .
wf:label a owl:DatatypeProperty ; rdfs:label "label"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Branch, Decision, Group, Oracle, Phase, Step, Validation"@ko .
wf:module a owl:DatatypeProperty ; rdfs:label "module"@ko ; rdfs:domain wf:WorkflowRef ; rdfs:range xsd:string .
wf:on a owl:DatatypeProperty ; rdfs:label "on"@ko ; rdfs:domain wf:Branch ; rdfs:range xsd:string .
wf:onFail a owl:DatatypeProperty ; rdfs:label "onFail"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Oracle, Validation"@ko .
wf:oracleType a owl:DatatypeProperty ; rdfs:label "oracleType"@ko ; rdfs:domain wf:Oracle ; rdfs:range xsd:string .
wf:owner a owl:DatatypeProperty ; rdfs:label "owner"@ko ; rdfs:domain wf:Decision ; rdfs:range xsd:string .
wf:parallel a owl:DatatypeProperty ; rdfs:label "parallel"@ko ; rdfs:domain wf:Phase ; rdfs:range xsd:boolean .
wf:passCriteria a owl:DatatypeProperty ; rdfs:label "passCriteria"@ko ; rdfs:domain wf:Validation ; rdfs:range xsd:string .
wf:ref a owl:DatatypeProperty ; rdfs:label "ref"@ko ; rdfs:domain wf:WorkflowRef ; rdfs:range xsd:string .
wf:showWrapper a owl:DatatypeProperty ; rdfs:label "showWrapper"@ko ; rdfs:domain wf:Phase ; rdfs:range xsd:boolean .
wf:sla a owl:DatatypeProperty ; rdfs:label "sla"@ko ; rdfs:domain wf:Decision ; rdfs:range xsd:string .
wf:status a owl:DatatypeProperty ; rdfs:label "status"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Decision, Group, Oracle, Phase, Step, Validation"@ko .
wf:subSteps a owl:DatatypeProperty ; rdfs:label "subSteps"@ko ; rdfs:domain wf:Step ; rdfs:range xsd:string .
wf:successCriteria a owl:DatatypeProperty ; rdfs:label "successCriteria"@ko ; rdfs:domain wf:Phase ; rdfs:range xsd:string .
wf:targetArtifact a owl:DatatypeProperty ; rdfs:label "targetArtifact"@ko ; rdfs:domain wf:Oracle ; rdfs:range xsd:string .
wf:threshold a owl:DatatypeProperty ; rdfs:label "threshold"@ko ; rdfs:range xsd:string ; rdfs:comment "used by: Decision, Oracle"@ko .
# ─── SlotFillingOracle 전용 프로퍼티 (schema 없음 — 여기서 직접 정의) ───────────
wf:hasSlot a owl:ObjectProperty ; rdfs:label "hasSlot"@ko ;
    rdfs:domain wf:SlotFillingOracle ; rdfs:range wf:EntitySlot ;
    rdfs:comment "SlotFillingOracle → EntitySlot 링크. 최소 1개 이상 선언 필수."@ko .
wf:slotName a owl:DatatypeProperty ; rdfs:label "slotName"@ko ;
    rdfs:domain wf:EntitySlot ; rdfs:range xsd:string ;
    rdfs:comment "슬롯 식별자 (예: cluster_terms, quality_gate)."@ko .
wf:slotConstraint a owl:DatatypeProperty ; rdfs:label "slotConstraint"@ko ;
    rdfs:domain wf:EntitySlot ; rdfs:range xsd:string ;
    rdfs:comment "슬롯 충족 조건 문자열 (예: 'selected_docs >= 5', 'encoding_ok AND no_dup'). 평가자가 직접 판정."@ko .
wf:slotFilled a owl:DatatypeProperty ; rdfs:label "slotFilled"@ko ;
    rdfs:domain wf:EntitySlot ; rdfs:range xsd:boolean ;
    rdfs:comment "슬롯 채움 여부. ABox 초기값 false. 평가자가 충족 확인 시 true로 갱신."@ko .
wf:orderTarget a owl:DatatypeProperty ; rdfs:label "orderTarget"@ko ;
    rdfs:domain wf:SlotFillingOracle ; rdfs:range xsd:string ;
    rdfs:comment "ALL hasSlot[*].slotFilled == true 조건 달성 시 order를 전달할 downstream step id."@ko .
wf:orderArtifact a owl:DatatypeProperty ; rdfs:label "orderArtifact"@ko ;
    rdfs:domain wf:SlotFillingOracle ; rdfs:range xsd:string ;
    rdfs:comment "slots_complete 시 생성되어 orderTarget step이 소비하는 order artifact 경로. wf:directory role:input으로 orderTarget에 연결되어야 한다."@ko .
wf:validation a owl:DatatypeProperty ; rdfs:label "validation"@ko ; rdfs:domain wf:Step ; rdfs:range xsd:string .

# ─── 그래프 층 (root-workflow 템플릿 개념 — schema 없음, 여기서 정의) ──────────────
wf:Task a owl:Class ; rdfs:label "Task"@ko ;
    rdfs:comment "실행·생성·검증을 수행하는 업무 노드 관측 상위 개념. Step/Validation/Group/WorkflowRef가 task 성격을 가진다. (schema 없음)"@ko .
wf:Module    a owl:Class ; rdfs:label "Module"@ko ;
    rdfs:comment "critical_dependencies 의 from/to 단위. (schema 없음)"@ko .
wf:Milestone a owl:Class ; rdfs:label "Milestone"@ko ;
    rdfs:comment "특정 Phase 를 가리키는 마일스톤. (schema 없음)"@ko .

wf:dependsOn a owl:ObjectProperty ; rdfs:label "dependsOn"@ko ;
    rdfs:domain wf:Phase ; rdfs:range wf:Phase ;
    rdfs:comment "root 템플릿 phases[].dependencies. 순환은 가능하나 산출물 재귀 소비 루프에는 Oracle 개입점이 필요하다. (phase.schema 엔 없음)"@ko .
wf:criticalDep a owl:ObjectProperty ; rdfs:label "criticalDep"@ko ;
    rdfs:domain wf:Module ; rdfs:range wf:Module ;
    rdfs:comment "critical_dependencies from→to. 구조 의존 관측 edge."@ko .
wf:milestoneOf a owl:ObjectProperty ; rdfs:label "milestoneOf"@ko ;
    rdfs:domain wf:Milestone ; rdfs:range wf:Phase .
wf:hasNode a owl:ObjectProperty ; rdfs:label "hasNode"@ko ;
    rdfs:domain wf:Phase ; rdfs:range wf:Node ;
    rdfs:comment "phase.steps[] 평탄화 에지."@ko .
wf:next a owl:ObjectProperty ; rdfs:label "next"@ko ;
    rdfs:domain wf:Node ; rdfs:range wf:Node ;
    rdfs:comment "process edge. phase.steps[] 의 기본 순차 실행 에지. decision branch goto 가 없을 때도 이 edge가 다음 실행 노드를 나타낸다."@ko .
wf:directory a owl:ObjectProperty ; rdfs:label "directory"@ko ;
    rdfs:domain wf:Node ;
    rdfs:comment "step.directories[] 항목(blank node: dirRole+dirPath). 라운드트립 가능."@ko .
wf:dirRole a owl:DatatypeProperty ; rdfs:label "dirRole"@ko ; rdfs:range xsd:string ;
    rdfs:comment "directory.role (input/output/reference/instruction 등)."@ko .
wf:dirPath a owl:DatatypeProperty ; rdfs:label "dirPath"@ko ; rdfs:range xsd:string ;
    rdfs:comment "directory.path. 교차-스킬(scaffold) 멤버십 대상."@ko .

# ─── 구조화 링크 (컨테이너 관계 — schema 필드 아님) ──────────────────────────────
wf:hasBranch a owl:ObjectProperty ; rdfs:label "hasBranch"@ko ;
    rdfs:domain wf:Decision ; rdfs:range wf:Branch ;
    rdfs:comment "decision.branches[] → Branch 노드(라운드트립)."@ko .
wf:gotoNode a owl:ObjectProperty ; rdfs:label "gotoNode"@ko ;
    rdfs:domain wf:Branch ; rdfs:range wf:Node ;
    rdfs:comment "process edge. branch.goto 문자열을 같은 workflow scope의 Node URI로 해석한 조건부 실행 에지."@ko .
wf:hasWorkflowRef a owl:ObjectProperty ; rdfs:label "hasWorkflowRef"@ko ;
    rdfs:domain wf:Phase ; rdfs:range wf:WorkflowRef ;
    rdfs:comment "phase.workflows[] 중 module 보유 항목 → WorkflowRef 노드(구조화). module 없는 doc-ref 는 wf:refersTo Literal 로 유지(dual-rep)."@ko .

# ─── narrative/meta 층 (root-workflow 템플릿 개념 — schema 없음, 여기서 정의) ──────
wf:Project a owl:Class ; rdfs:label "Project"@ko ;
    rdfs:comment "root-workflow 메타(project:). name/version/description/owner/created. (schema 없음)"@ko .
wf:KeyDecision a owl:Class ; rdfs:label "KeyDecision"@ko ;
    rdfs:comment "key_decisions[] 항목. decisionText/rationale/impactModule. (schema 없음)"@ko .
wf:SuccessCriterion a owl:Class ; rdfs:label "SuccessCriterion"@ko ;
    rdfs:comment "top-level success_criteria[] (scKey→scValue) 항목. (schema 없음)"@ko .
wf:CriticalDependency a owl:Class ; rdfs:label "CriticalDependency"@ko ;
    rdfs:comment "critical_dependencies[] 항목(서술 포함). from/to 는 wf:criticalDep 에지로도 투영(dual-rep). (schema 없음)"@ko .
wf:MetaBlock a owl:Class ; rdfs:label "MetaBlock"@ko ;
    rdfs:comment "top-level non-phase 메타 블록(workflow/module/meta/metadata + 소비자 x_* 확장). 임의 중첩 구조를 canonical JSON literal(rawJson)로 무손실 보존. (schema 없음)"@ko .

wf:blockKey a owl:DatatypeProperty ; rdfs:label "blockKey"@ko ; rdfs:domain wf:MetaBlock ; rdfs:range xsd:string ;
    rdfs:comment "메타 블록의 원본 top-level 키(workflow/module/meta/x_msm 등)."@ko .
wf:rawJson a owl:DatatypeProperty ; rdfs:label "rawJson"@ko ; rdfs:domain wf:MetaBlock ; rdfs:range xsd:string ;
    rdfs:comment "메타 블록 원본을 sort_keys canonical JSON 으로 직렬화(무손실·결정적)."@ko .

wf:version a owl:DatatypeProperty ; rdfs:label "version"@ko ; rdfs:domain wf:Project ; rdfs:range xsd:string .
wf:created a owl:DatatypeProperty ; rdfs:label "created"@ko ; rdfs:domain wf:Project ; rdfs:range xsd:string .
wf:decisionText a owl:DatatypeProperty ; rdfs:label "decisionText"@ko ; rdfs:domain wf:KeyDecision ; rdfs:range xsd:string .
wf:rationale a owl:DatatypeProperty ; rdfs:label "rationale"@ko ; rdfs:domain wf:KeyDecision ; rdfs:range xsd:string .
wf:impactModule a owl:DatatypeProperty ; rdfs:label "impactModule"@ko ; rdfs:domain wf:KeyDecision ; rdfs:range xsd:string ;
    rdfs:comment "key_decision.impact_modules[] 항목."@ko .
wf:scKey a owl:DatatypeProperty ; rdfs:label "scKey"@ko ; rdfs:domain wf:SuccessCriterion ; rdfs:range xsd:string .
wf:scValue a owl:DatatypeProperty ; rdfs:label "scValue"@ko ; rdfs:domain wf:SuccessCriterion ; rdfs:range xsd:string .
wf:cdFrom a owl:DatatypeProperty ; rdfs:label "cdFrom"@ko ; rdfs:domain wf:CriticalDependency ; rdfs:range xsd:string .
wf:cdTo a owl:DatatypeProperty ; rdfs:label "cdTo"@ko ; rdfs:domain wf:CriticalDependency ; rdfs:range xsd:string .
wf:milestoneDate a owl:DatatypeProperty ; rdfs:label "milestoneDate"@ko ; rdfs:domain wf:Milestone ; rdfs:range xsd:string .

# 통제어휘 (skos)
wf:JudgeScheme a skos:ConceptScheme ; skos:prefLabel "Judge Levels"@ko .
wf:HITL a skos:Concept ; skos:inScheme wf:JudgeScheme ; skos:notation "HITL" .
wf:HITLFE a skos:Concept ; skos:inScheme wf:JudgeScheme ; skos:notation "HITLFE" .
wf:HOTL a skos:Concept ; skos:inScheme wf:JudgeScheme ; skos:notation "HOTL" .
wf:HOOTL a skos:Concept ; skos:inScheme wf:JudgeScheme ; skos:notation "HOOTL" .

