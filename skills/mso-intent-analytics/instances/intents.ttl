@prefix mso:  <https://mso.dev/ontology/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ═══════════════════════════════════════════════════════════
# MSO Canonical Intent Instances  (v0.3.1)
# 10 intents — query(3) / create(2) / update(4) / delete(1)
# ═══════════════════════════════════════════════════════════

mso:Intent    a rdfs:Class ; rdfs:label "Intent" .
mso:SlotSpec  a rdfs:Class ; rdfs:label "SlotSpec" .

# ─── QUERY ──────────────────────────────────────────────────

mso:query_run_status a mso:Intent ;
    mso:intent_id "query_run_status" ;
    mso:verb_concept mso:QueryVerb ;
    mso:target_concept mso:RunContext ;
    mso:trigger_keywords ("내 run" "진행률" "지금 어떻게" "run 상태" "어떻게 되고" "현황") ;
    mso:example_utterances ("run-2025 어떻게 돼?" "내 run 현황 보여줘" "지금 어떻게 되고 있어?") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "run_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "false" ;
          mso:fill_policy "session_context" ;
          rdfs:comment "없으면 SessionContext.run_ids[0] 사용" ]
    ) .

mso:query_ticket_list a mso:Intent ;
    mso:intent_id "query_ticket_list" ;
    mso:verb_concept mso:QueryVerb ;
    mso:target_concept mso:TicketEvent ;
    mso:trigger_keywords ("ticket" "active 작업" "할 일" "active ticket" "티켓 목록") ;
    mso:example_utterances ("오늘 active ticket" "지금 진행 중인 작업 보여줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "filter_status" ;
          mso:slot_type "enum_value" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "active" ]
        [ a mso:SlotSpec ;
          mso:slot_name "date_range" ;
          mso:slot_type "timestamp" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "today" ]
    ) .

mso:query_audit_log a mso:Intent ;
    mso:intent_id "query_audit_log" ;
    mso:verb_concept mso:QueryVerb ;
    mso:target_concept mso:RunManifest ;
    mso:trigger_keywords ("audit" "log" "어제 fail" "실패 기록" "로그" "감사") ;
    mso:example_utterances ("어제 fail한 ticket" "audit log 보여줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "filter_status" ;
          mso:slot_type "enum_value" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "failed" ]
        [ a mso:SlotSpec ;
          mso:slot_name "date_range" ;
          mso:slot_type "timestamp" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "yesterday" ]
    ) .

# ─── CREATE ─────────────────────────────────────────────────

mso:dispatch_ticket a mso:Intent ;
    mso:intent_id "dispatch_ticket" ;
    mso:verb_concept mso:CreateVerb ;
    mso:target_concept mso:TicketEvent ;
    mso:trigger_keywords ("재실행" "dispatch" "다시" "retry" "재시도") ;
    mso:example_utterances ("ticket-217 재실행" "방금 fail한 티켓 다시 실행해줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "ticket_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "true" ;
          mso:fill_policy "ask" ]
        [ a mso:SlotSpec ;
          mso:slot_name "reason" ;
          mso:slot_type "enum_value" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "manual_retry" ]
    ) .

mso:create_ticket a mso:Intent ;
    mso:intent_id "create_ticket" ;
    mso:verb_concept mso:CreateVerb ;
    mso:target_concept mso:TicketEvent ;
    mso:trigger_keywords ("새 작업" "ticket 추가" "작업 추가" "티켓 만들어") ;
    mso:example_utterances ("ticket 새로 만들어" "새 작업 추가해줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "task_description" ;
          mso:slot_type "free_text" ;
          mso:required "true" ;
          mso:fill_policy "ask" ]
        [ a mso:SlotSpec ;
          mso:slot_name "priority" ;
          mso:slot_type "enum_value" ;
          mso:required "false" ;
          mso:fill_policy "default" ;
          mso:default_value "normal" ]
        [ a mso:SlotSpec ;
          mso:slot_name "workflow_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "false" ;
          mso:fill_policy "session_context" ]
    ) .

# ─── UPDATE ─────────────────────────────────────────────────

mso:pause_workflow a mso:Intent ;
    mso:intent_id "pause_workflow" ;
    mso:verb_concept mso:UpdateVerb ;
    mso:target_concept mso:WorkflowEntity ;
    mso:trigger_keywords ("멈춰" "pause" "대기" "일시정지" "중단해") ;
    mso:example_utterances ("이 워크플로우 멈춰" "잠깐 pause해줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "workflow_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "true" ;
          mso:fill_policy "ask" ]
    ) .

mso:resume_workflow a mso:Intent ;
    mso:intent_id "resume_workflow" ;
    mso:verb_concept mso:UpdateVerb ;
    mso:target_concept mso:WorkflowEntity ;
    mso:trigger_keywords ("재개" "resume" "다시 진행" "계속해") ;
    mso:example_utterances ("다시 진행해" "워크플로우 resume") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "workflow_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "false" ;
          mso:fill_policy "session_context" ]
    ) .

mso:override_hitl_gate a mso:Intent ;
    mso:intent_id "override_hitl_gate" ;
    mso:verb_concept mso:UpdateVerb ;
    mso:target_concept mso:HITLGateContext ;
    mso:trigger_keywords ("gate 통과" "H1 해제" "override" "gate 해제" "H2 해제" "gate skip") ;
    mso:example_utterances ("H1 gate 해제해줘" "gate 통과시켜") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "gate_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "false" ;
          mso:fill_policy "session_context" ;
          rdfs:comment "없으면 현재 Run의 active gate" ]
        [ a mso:SlotSpec ;
          mso:slot_name "override_reason" ;
          mso:slot_type "free_text" ;
          mso:required "false" ;
          mso:fill_policy "ask" ]
    ) .

mso:update_ticket_priority a mso:Intent ;
    mso:intent_id "update_ticket_priority" ;
    mso:verb_concept mso:UpdateVerb ;
    mso:target_concept mso:TicketEvent ;
    mso:trigger_keywords ("priority" "우선순위" "priority 올려" "priority 내려") ;
    mso:example_utterances ("ticket-217 priority 높여" "이 ticket 우선순위 올려줘") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "ticket_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "true" ;
          mso:fill_policy "ask" ]
        [ a mso:SlotSpec ;
          mso:slot_name "new_priority" ;
          mso:slot_type "enum_value" ;
          mso:required "true" ;
          mso:fill_policy "ask" ]
    ) .

# ─── DELETE ─────────────────────────────────────────────────

mso:cancel_run a mso:Intent ;
    mso:intent_id "cancel_run" ;
    mso:verb_concept mso:DeleteVerb ;
    mso:target_concept mso:RunContext ;
    mso:trigger_keywords ("취소" "중단" "abort" "cancel" "run 취소" "stop") ;
    mso:example_utterances ("이 run 취소해줘" "실행 중단해") ;
    mso:slot_specs (
        [ a mso:SlotSpec ;
          mso:slot_name "run_ref" ;
          mso:slot_type "entity_ref" ;
          mso:required "false" ;
          mso:fill_policy "session_context" ]
        [ a mso:SlotSpec ;
          mso:slot_name "cancel_reason" ;
          mso:slot_type "free_text" ;
          mso:required "false" ;
          mso:fill_policy "ask" ]
    ) .
